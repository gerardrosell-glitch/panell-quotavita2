const MIXP={pm:0.55,dmR:0.58,dmO:0.70,fixed:160000,off:0.275,rev:600000};
const MIXES=[0,0.10,0.35,0.50,1.0];
function mixCalc(d,dm){const bl=d*dm+(1-d)*MIXP.pm;const cm=bl-MIXP.off;return {bl,cm,be:MIXP.fixed/cm,ebit:MIXP.rev*cm-MIXP.fixed};}
function drawMix(){
