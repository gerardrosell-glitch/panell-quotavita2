    {label:'EBIT amb sèrum gratis (beguda 70%)',data:cO.map(x=>x.ebit),backgroundColor:'#5b7d3a',borderRadius:5}]},options:legOpt});
  mk('chMixBE',{type:'bar',data:{labels:lab,datasets:[{data:cR.map(x=>x.be),backgroundColor:'#C2872B',borderRadius:5}]},options:baseOpts(eurk)});
