
<!DOCTYPE html>
<html lang="ca">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Quota Vita — Model Estratègic 2026–2028</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.5.0/dist/chart.umd.js"></script>
<style>
  :root{ color-scheme: light;
    --bg:#FBF7F2; --card:#ffffff; --ink:#2b2320; --muted:#8a7d75; --line:#ece3da;
    --brand:#A0493A; --brand-soft:#f3e7e2; --budget:#CFC1B2; --real:#A0493A;
    --good:#5b7d3a; --bad:#b23a2e; --warn:#C2872B; --scn:#6E7B4F; --blue:#3E7378; --gold:#C2872B;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);font:14px/1.5 -apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;padding:16px}
  h1{font-size:20px;margin:0 0 2px} h2{font-size:13px;margin:0 0 11px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em}
  h3{font-size:14px;margin:16px 0 8px}
  .top{display:flex;justify-content:space-between;align-items:flex-end;gap:12px;flex-wrap:wrap;margin-bottom:12px}
  .sub{color:var(--muted);font-size:12.5px}
  .tabs{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:14px;border-bottom:1px solid var(--line)}
  .tab{padding:8px 13px;border:none;border-bottom:2px solid transparent;background:none;color:var(--muted);font-weight:600;cursor:pointer;font-size:13px}
  .tab.active{color:var(--brand);border-bottom-color:var(--brand)}
  .panel{display:none} .panel.active{display:block}
  .grid{display:grid;gap:13px}
  .kpis{grid-template-columns:repeat(4,1fr)} .k3{grid-template-columns:repeat(3,1fr)}
  @media(max-width:780px){.kpis,.k3{grid-template-columns:repeat(2,1fr)}}
  .card{background:var(--card);border:1px solid var(--line);border-radius:13px;padding:15px}
  .kpi .lbl{color:var(--muted);font-size:12px;margin-bottom:5px}
  .kpi .val{font-size:22px;font-weight:700;letter-spacing:-.02em}
  .kpi .delta{font-size:12.5px;font-weight:600;margin-top:3px}
  .pos{color:var(--good)} .neg{color:var(--bad)} .mut{color:var(--muted);font-weight:500}
  .row2{display:grid;grid-template-columns:1.4fr 1fr;gap:13px;margin-top:13px}
  @media(max-width:880px){.row2{grid-template-columns:1fr}}
  table{width:100%;border-collapse:collapse;font-size:13px}
  th,td{padding:6px 9px;text-align:right;border-bottom:1px solid var(--line)}
  th:first-child,td:first-child{text-align:left}
  th{color:var(--muted);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:.03em}
  tr.tot td{font-weight:700;border-top:2px solid var(--line)}
  tr.sub-h td{font-weight:700;color:var(--brand);background:var(--brand-soft)}
  .chip{display:inline-block;padding:1px 8px;border-radius:20px;font-weight:600;font-size:12px}
  .chip.g{background:#eaf0e0;color:var(--good)} .chip.b{background:#f7e5e2;color:var(--bad)} .chip.w{background:#f6edd7;color:var(--warn)}
  .note{font-size:11.5px;color:var(--muted);margin-top:9px}
  .lead{font-size:14px;color:var(--ink);line-height:1.6;max-width:70ch}
  canvas{max-height:300px}
  .legend{display:flex;gap:16px;font-size:12px;color:var(--muted);margin-top:8px;flex-wrap:wrap}
  .sw{display:inline-block;width:11px;height:11px;border-radius:3px;margin-right:5px;vertical-align:-1px}
  .funnel{display:flex;flex-direction:column;gap:6px;margin-top:6px}
  .funnel .bar{background:var(--brand);color:#fff;border-radius:8px;padding:9px 13px;font-weight:600;display:flex;justify-content:space-between;align-items:center}
  .funnel .bar small{font-weight:500;opacity:.85}
  .slider label{display:flex;justify-content:space-between;font-weight:600;margin-bottom:5px}
  .slider label span{color:var(--brand)}
  input[type=range]{width:100%;accent-color:var(--brand)}
  .assum{display:grid;grid-template-columns:repeat(2,1fr);gap:15px 22px}
  @media(max-width:760px){.assum{grid-template-columns:1fr}}
  .scnres{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:14px}
  .scnres .b{background:var(--brand-soft);border-radius:10px;padding:11px;text-align:center}
  .scnres .b .y{font-size:12px;color:var(--muted)} .scnres .b .n{font-size:18px;font-weight:700}
  .verdict{background:var(--brand-soft);border-left:4px solid var(--brand);border-radius:0 10px 10px 0;padding:12px 15px;margin-top:12px;font-size:13px;line-height:1.55}
  .two{display:grid;grid-template-columns:1fr 1fr;gap:13px}@media(max-width:760px){.two{grid-template-columns:1fr}}
</style>
